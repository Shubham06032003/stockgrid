PORT=5000
NODE_ENV=development
APP_NAME=StockGrid

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Google Gemini AI
GEMINI_API_KEY=

# CORS
FRONTEND_URL=http://localhost:5173

# Password Reset Email
RESET_PASSWORD_PATH=/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
PASSWORD_RESET_REQUEST_MAX_PER_HOUR=3
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support.stockgrid@gmail.com   
SMTP_PASS=Stock@1234
MAIL_FROM_EMAIL=support.stockgrid@gmail.com   
MAIL_FROM_NAME=StockGrid
